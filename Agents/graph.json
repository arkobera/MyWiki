    {
      "id": "document:Attention_2017.pdf",
      "type": "document",
      "position": {
        "x": 520.0,
        "y": 860.0
      },
      "data": {
        "label": "Attention_2017.pdf",
        "kind": "document",
        "summary": "The Transformer model architecture, which includes components like Scaled Dot-Product Attention and Multi-Head Attention, is designed to handle input-output dependencies in sequences. Transformer models have shown to achieve better BLEU scores in translation tasks compared to previous state-of-the-art methods. Various variations on the Transformer architecture have been proposed to enhance its performance and generalization capabilities.",
        "category": "Artificial Intelligence",
        "embedding_id": "attention-2017-007ce33735",
        "embedding_path": "embeddings/attention-2017-007ce33735",
        "source_file": "raw/Attention_2017.pdf",
        "keyword_count": 5,
        "document_count": 0
      }
    },
    {
      "id": "document:KD_Final_Report.pdf",
      "type": "document",
      "position": {
        "x": 520.0,
        "y": 1030.0
      },
      "data": {
        "label": "KD_Final_Report.pdf",
        "kind": "document",
        "summary": "The paper introduces a knowledge distillation-based hybrid CNN-Transformer framework for real-time imagined speech. The proposed model aims to improve the efficiency and accuracy of speech recognition systems. 0 Experimental results demonstrate the effectiveness of the framework in various speech datasets.",
        "category": "Deep Learning",
        "embedding_id": "kd-final-report-7de717c72a",
        "embedding_path": "embeddings/kd-final-report-7de717c72a",
        "source_file": "raw/KD_Final_Report.pdf",
        "keyword_count": 5,
        "document_count": 0
      }
    },
    {
      "id": "document:Vision_Trf.pdf",
      "type": "document",
      "position": {
        "x": 740.0,
        "y": 180.0
      },
      "data": {
        "label": "Vision_Trf.pdf",
        "kind": "document",
        "summary": "The paper introduces a novel Transformer Encoder MLP Head for Vision tasks, inheriting CNNs' strengths. The MLP contains two layers with a specific hidden size and MLP size, optimized for ImageNet-21k and JFT-300M datasets. The study demonstrates the model's performance on ImageNet-21k and JFT-300M, achieving competitive results.",
        "category": "Computer Vision",
        "embedding_id": "vision-trf-4ebc453f0f",
        "embedding_path": "embeddings/vision-trf-4ebc453f0f",
        "source_file": "raw/Vision_Trf.pdf",
        "keyword_count": 5,
        "document_count": 0
      }
